  /api/users/:
    get:
      operationId: users_list
      description: |-
        LIST /api/users/
        Get all users with filtering and search
        Manager only

        Query Parameters:
        - role: Filter by role (Manager, Cashier, Baker, Storekeeper)
        - status: Filter by status (active, inactive, suspended)
        - search: Search by username, full_name, email, employee_id, contact
        - ordering: Sort by id, username, created_at, full_name, employee_id

        Response: 200 OK with list of users
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: role
        schema:
          type: string
          enum:
          - Baker
          - Cashier
          - Manager
          - Storekeeper
        description: |-
          * `Manager` - Manager
          * `Cashier` - Cashier
          * `Baker` - Baker
          * `Storekeeper` - Storekeeper

          * `Manager` - Manager
          * `Cashier` - Cashier
          * `Baker` - Baker
          * `Storekeeper` - Storekeeper
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: status
        schema:
          type: string
          enum:
          - active
          - inactive
          - suspended
        description: |-
          * `active` - Active
          * `inactive` - Inactive
          * `suspended` - Suspended

          * `active` - Active
          * `inactive` - Inactive
          * `suspended` - Suspended
      tags:
      - users
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedUserListList'
          description: ''
    post:
      operationId: users_create
      description: |-
        CREATE /api/users/
        Create a new user
        Manager only

        Request Body:
        {
            "username": "string",
            "password": "string (8+ chars, uppercase, lowercase, number)",
            "password_confirm": "string",
            "email": "string",
            "full_name": "string",
            "contact": "string",
            "nic": "string",
            "role": "Manager|Cashier|Baker|Storekeeper"
        }

        Response: 201 Created with user details
        Response: 400 Bad Request if validation fails
      tags:
      - users
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UserCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/UserCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/UserCreateRequest'
        required: true
      security:
      - tokenAuth: []
      responses:
