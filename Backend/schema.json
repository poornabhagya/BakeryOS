      type: object
      description: |-
        Serializer for creating/updating batches.
        Includes custom validation rules.
      properties:
        ingredient_id:
          type: integer
          description: Ingredient this batch belongs to
        quantity:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Total quantity received for this batch
        current_qty:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Current remaining quantity in this batch
        cost_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          nullable: true
          description: Cost per unit (optional for financial tracking)
        made_date:
          type: string
          format: date-time
          description: Date batch was received/created
        expire_date:
          type: string
          format: date-time
          description: Expiry date for this batch
    PatchedCategoryUpdateRequest:
      type: object
      description: |-
        Serializer for updating categories
        name and type are read-only (can't change once created)
        Only description can be updated
      properties:
        description:
          type: string
          nullable: true
          description: Detailed description of category
    PatchedDiscountCreateRequest:
      type: object
      description: Serializer for creating/updating discounts with validation
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 100
        description:
          type: string
          nullable: true
        discount_type:
          enum:
          - Percentage
          - FixedAmount
          type: string
          description: |-
            * `Percentage` - Percentage (%)
            * `FixedAmount` - Fixed Amount (Rs)
        value:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: 'For Percentage: 0-100, For FixedAmount: any positive number'
        applicable_to:
          enum:
          - All
          - Category
          - Product
          type: string
          description: |-
            * `All` - All Products
            * `Category` - Specific Category
            * `Product` - Specific Product
        target_category_id:
          type: integer
          nullable: true
        target_product_id:
          type: integer
          nullable: true
        start_date:
          type: string
          format: date
          nullable: true
        end_date:
          type: string
          format: date
          nullable: true
        start_time:
          type: string
          format: time
          nullable: true
        end_time:
          type: string
          format: time
          nullable: true
        is_active:
          type: boolean
    PatchedDiscountDetailRequest:
      type: object
