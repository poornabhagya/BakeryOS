    ProductCreate:
      type: object
      description: |-
        Serializer for creating and updating products.
        Validates required fields and constraints.
        Used for: POST /api/products/, PUT /api/products/{id}/, PATCH /api/products/{id}/

        Validation:
        - name: Non-empty, unique per category, sanitized
        - cost_price: Must be positive (> 0)
        - selling_price: Must be > cost_price
        - shelf_life: Must be positive integer
        - current_stock: Must be non-negative
      properties:
        category_id:
          type: integer
          description: Must be a Product-type category
        name:
          type: string
          description: e.g., 'White Bread Loaf', 'Chocolate Cake'
          maxLength: 100
        description:
          type: string
          nullable: true
          description: Product description for display
        image_url:
          type: string
          format: uri
          nullable: true
          description: URL to product image
          maxLength: 200
        cost_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Cost to produce per unit
        selling_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Selling price per unit
        current_stock:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Current quantity in stock (pieces/units)
        shelf_life:
          type: integer
          maximum: 9223372036854775807
          minimum: 1
          format: int64
          description: How long product lasts after production
        shelf_unit:
          enum:
          - hours
          - days
          - weeks
          type: string
          description: |-
            Time unit for shelf_life

            * `hours` - Hours
            * `days` - Days
            * `weeks` - Weeks
      required:
      - category_id
      - cost_price
      - name
      - selling_price
