  /api/ingredient-stock-history/:
    get:
      operationId: ingredient_stock_history_list
      description: |-
        ViewSet for viewing ingredient stock history (audit trail).

        Provides read-only access to all ingredient stock transactions
        including batch additions, usage, wastage, and adjustments.

        Features:
        - Filter by ingredient, batch, transaction type, date range
        - List and detail views
        - Pagination support
        - Ordering support
        - Summary by transaction type
      parameters:
      - in: query
        name: batch_id
        schema:
          type: integer
      - in: query
        name: ingredient_id
        schema:
          type: integer
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: transaction_type
        schema:
          type: string
          enum:
          - AddStock
          - Adjustment
          - UseStock
          - Wastage
        description: |-
          Type of transaction

          * `AddStock` - Add Stock
          * `UseStock` - Use Stock
          * `Wastage` - Wastage
          * `Adjustment` - Adjustment
      tags:
      - ingredient-stock-history
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedIngredientStockHistoryListList'
          description: ''
