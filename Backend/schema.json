        reported_by:
          type: integer
          nullable: true
          description: User who reported the wastage
    PatchedProductBatchUpdateRequest:
      type: object
      description: Serializer for updating product batch
      properties:
        quantity:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Total quantity produced in this batch
        made_date:
          type: string
          format: date
          description: Date when batch was produced
        status:
          enum:
          - Active
          - Expired
          - Used
          type: string
          description: |-
            Active, Expired, or Used

            * `Active` - Active
            * `Expired` - Expired
            * `Used` - Used
        notes:
          type: string
          nullable: true
          description: 'Notes about production e.g., ''Oven #2'', ''Made by Baker1'''
    PatchedProductCreateRequest:
      type: object
      description: |-
        Serializer for creating and updating products.
        Validates required fields and constraints.
        Used for: POST /api/products/, PUT /api/products/{id}/, PATCH /api/products/{id}/

        Validation:
        - name: Non-empty, unique per category, sanitized
        - cost_price: Must be positive (> 0)
        - selling_price: Must be > cost_price
        - shelf_life: Must be positive integer
        - current_stock: Must be non-negative
      properties:
        category_id:
          type: integer
          description: Must be a Product-type category
        name:
          type: string
          minLength: 1
          description: e.g., 'White Bread Loaf', 'Chocolate Cake'
          maxLength: 100
        description:
          type: string
          nullable: true
          description: Product description for display
        image_url:
          type: string
          format: uri
          nullable: true
          description: URL to product image
          maxLength: 200
        cost_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Cost to produce per unit
        selling_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Selling price per unit
        current_stock:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Current quantity in stock (pieces/units)
        shelf_life:
          type: integer
          maximum: 9223372036854775807
          minimum: 1
          format: int64
          description: How long product lasts after production
        shelf_unit:
          enum:
          - hours
          - days
          - weeks
          type: string
          description: |-
            Time unit for shelf_life

            * `hours` - Hours
            * `days` - Days
            * `weeks` - Weeks
    PatchedProductWastageListRequest:
      type: object
      description: |-
        List serializer for product wastages.
        Shows summary information without nested objects.
      properties:
        product_id:
          type: integer
          description: The product that was wasted
        quantity:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Quantity of product wasted
        unit_cost:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Cost per unit at time of wastage
        reason_id:
          type: integer
          description: Reason for wastage
        reported_by:
          type: integer
          nullable: true
          description: User who reported the wastage
    PatchedUserStatusRequest:
      type: object
      description: |-
        Minimal serializer for status PATCH endpoint
        Only allows updating status field
      properties:
        status:
          enum:
          - active
          - inactive
          - suspended
          type: string
          description: |-
            * `active` - Active
            * `inactive` - Inactive
            * `suspended` - Suspended
    PatchedUserUpdateRequest:
      type: object
      description: |-
        Serializer for updating users

        Rules:
        - Non-managers can only update: username, email, full_name, contact, nic
        - Non-managers CANNOT update: role, status, is_active
        - Managers can update everything except password (use separate endpoint)
      properties:
        password:
          type: string
          writeOnly: true
          minLength: 8
          description: Leave blank to keep current password
        email:
          type: string
          format: email
          title: Email address
          maxLength: 254
        full_name:
          type: string
          minLength: 1
          maxLength: 255
        contact:
          type: string
          nullable: true
          maxLength: 20
        nic:
          type: string
          nullable: true
          maxLength: 50
        role:
          enum:
          - Manager
          - Cashier
          - Baker
          - Storekeeper
          type: string
          description: |-
            * `Manager` - Manager
            * `Cashier` - Cashier
            * `Baker` - Baker
            * `Storekeeper` - Storekeeper
        status:
          enum:
          - active
          - inactive
          - suspended
          type: string
          description: |-
            * `active` - Active
            * `inactive` - Inactive
            * `suspended` - Suspended
        avatar_color:
          type: string
          minLength: 1
          maxLength: 20
