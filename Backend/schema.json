          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          readOnly: true
          description: Stock quantity after transaction
        change_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          readOnly: true
          description: Change in quantity (positive for additions, negative for removals)
        sale_bill_number:
          type: string
          readOnly: true
          nullable: true
          description: Bill number if this is from a sale
        notes:
          type: string
          readOnly: true
          nullable: true
          description: Additional details about the transaction
        user_id:
          type: integer
          readOnly: true
          nullable: true
