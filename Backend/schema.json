  /api/product-stock-history/:
    get:
      operationId: product_stock_history_list
      description: |-
        ViewSet for viewing product stock history (audit trail).

        Provides read-only access to all product stock transactions
        including sales, batch additions, wastage, and adjustments.

        Features:
        - Filter by product, transaction type, date range
        - Search by bill number
        - List and detail views
        - Pagination support
        - Ordering support
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: product_id
        schema:
          type: integer
      - in: query
        name: transaction_type
        schema:
          type: string
          enum:
          - AddStock
          - ReturnStock
          - StockAdjustment
          - UseStock
          - WasteStock
        description: |-
          Type of stock change

          * `AddStock` - Add Stock (Production/Batch)
          * `UseStock` - Use Stock (Sale)
          * `ReturnStock` - Return Stock (Product Return)
          * `WasteStock` - Waste Stock (Spoilage/Damage)
          * `StockAdjustment` - Stock Adjustment (Inventory Correction)
      tags:
      - product-stock-history
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedProductStockHistoryListList'
          description: ''
