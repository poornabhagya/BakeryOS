    PatchedIngredientUpdateRequest:
      type: object
      description: |-
        Serializer for updating existing ingredients.

        Only allows updating specific fields (not name, category, tracking_type).
      properties:
        supplier:
          type: string
          nullable: true
          description: Supplier company name
          maxLength: 100
        supplier_contact:
          type: string
          nullable: true
          description: Supplier phone/email
          maxLength: 100
        base_unit:
          type: string
          minLength: 1
          description: e.g., 'kg', 'liters', 'pieces'
          maxLength: 20
        low_stock_threshold:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Alert threshold for low stock
        shelf_life:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
          description: Number of days/weeks/months before expiry
        shelf_unit:
          enum:
          - days
          - weeks
          - months
          - years
          type: string
          description: |-
            Unit for shelf life (days, weeks, months)

            * `days` - Days
            * `weeks` - Weeks
            * `months` - Months
            * `years` - Years
        is_active:
          type: boolean
          description: Soft delete support - set to False instead of deleting
    PatchedIngredientWastageListRequest:
      type: object
