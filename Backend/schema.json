openapi: 3.0.3
info:
  title: BakeryOS API
  version: 1.0.0
  description: Bakery Management System API - Complete inventory, sales, and production
    management
  contact:
    name: BakeryOS Development Team
    url: https://bakeryos.local
    email: support@bakeryos.local
  license:
    name: MIT License
    url: https://opensource.org/licenses/MIT
paths:
  /api/analytics/inventory/expired/:
    get:
      operationId: analytics_inventory_expired_retrieve
      description: Get expired ingredients and their value
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/inventory/ingredient_usage/:
    get:
      operationId: analytics_inventory_ingredient_usage_retrieve
      description: Get ingredient usage rates
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/inventory/stock_value/:
    get:
      operationId: analytics_inventory_stock_value_retrieve
      description: Calculate total inventory value at cost price
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/inventory/turnover/:
    get:
      operationId: analytics_inventory_turnover_retrieve
      description: Calculate stock turnover rate per product
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/inventory/wastage_summary/:
    get:
      operationId: analytics_inventory_wastage_summary_retrieve
      description: Get wastage breakdown by reason
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/inventory/wastage_trend/:
    get:
      operationId: analytics_inventory_wastage_trend_retrieve
      description: Get wastage trends over time (daily/weekly/monthly)
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/sales/by_cashier/:
    get:
      operationId: analytics_sales_by_cashier_retrieve
      description: Get sales by cashier
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/sales/by_category/:
    get:
      operationId: analytics_sales_by_category_retrieve
      description: Get sales by product category
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/sales/daily/:
    get:
      operationId: analytics_sales_daily_retrieve
      description: Get daily sales totals
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/sales/monthly/:
    get:
      operationId: analytics_sales_monthly_retrieve
      description: Get monthly sales totals
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/sales/revenue/:
    get:
      operationId: analytics_sales_revenue_retrieve
      description: Get revenue vs cost analysis
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/sales/top_products/:
    get:
      operationId: analytics_sales_top_products_retrieve
      description: Get top-selling products
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/analytics/sales/weekly/:
    get:
      operationId: analytics_sales_weekly_retrieve
      description: Get weekly sales totals
      tags:
      - analytics
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/auth/login/:
    post:
      operationId: auth_login_create
      description: |-
        POST /api/auth/login/ - Authenticate user and obtain auth token.

        Request body:
        {
            "username": "string",
            "password": "string"
        }

        Response (200):
        {
            "token": "string (Auth token)",
            "user": {
                "id": integer,
                "username": "string",
                "full_name": "string",
                "email": "string",
                "role": "string",
                "employee_id": "string",
                "status": "string"
            }
        }

        Response (401):
        {
            "error": "Invalid credentials or user is inactive"
        }
      tags:
      - auth
      security:
      - tokenAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/auth/logout/:
    post:
      operationId: auth_logout_create
      description: |-
        POST /api/auth/logout/ - Logout user and delete token.

        Headers:
        {
            "Authorization": "Token <token>"
        }

        Response (200):
        {
            "detail": "Successfully logged out."
        }

        Response (400):
        {
            "error": "Invalid token"
        }
      tags:
      - auth
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/auth/me/:
    get:
      operationId: auth_me_retrieve
      description: |-
        GET /api/auth/me/ - Get current authenticated user information.

        Headers:
        {
            "Authorization": "Token <token>"
        }

        Response (200):
        {
            "id": integer,
            "username": "string",
            "email": "string",
            "full_name": "string",
            "employee_id": "string",
            "role": "string",
            "status": "string",
            "contact": "string",
            "nic": "string",
            "avatar_color": "string",
            "is_active": boolean,
            "is_staff": boolean,
            "created_at": "datetime",
            "updated_at": "datetime",
            "last_login": "datetime"
        }

        Response (401):
        {
            "detail": "Authentication credentials were not provided."
        }
      tags:
      - auth
      security:
      - tokenAuth: []
      responses:
        '200':
          description: No response body
  /api/batches/:
    get:
      operationId: batches_list
      description: |-
        ViewSet for IngredientBatch management.

        Features:
        - Auto-generated batch_id (BATCH-1001, BATCH-1002, etc.)
        - Quantity tracking with FIFO ordering
        - Expiry date management and alerts
        - Cost tracking for financial reporting
        - Automatic ingredient total_quantity sync

        Endpoints:
        - GET    /api/batches/                  List all batches (paginated, filtered)
        - POST   /api/batches/                  Create new batch
        - GET    /api/batches/{id}/             Get batch details
        - PUT    /api/batches/{id}/             Full update
        - PATCH  /api/batches/{id}/             Partial update
        - DELETE /api/batches/{id}/             Delete batch

        Custom Actions:
        - GET    /api/batches/expiring/         Get batches expiring within 2 days
        - GET    /api/batches/{id}/consume/     Consume from batch (FIFO)
        - GET    /api/ingredients/{id}/batches/ Get all active batches for ingredient (FIFO)

        Filtering:
        - ?ingredient_id=1         Filter by ingredient
        - ?status=Active           Filter by status (Active, Expired, Used)
        - ?expiring_within=7       Batches expiring within N days
        - ?search=BATCH-1001       Search by batch_id or ingredient name
        - ?ordering=expire_date    Sort by field

        Permissions:
        - Storekeeper: Full CRUD (create, update, delete)
        - Manager: Full access (can do everything)
        - Baker: Read-only (list, detail)
        - Cashier & Others: No access
      parameters:
      - in: query
        name: ingredient_id
        schema:
          type: integer
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: status
        schema:
          type: string
          enum:
          - Active
          - Expired
          - Used
        description: |-
          Current status of the batch

          * `Active` - Active
          * `Expired` - Expired
          * `Used` - Used
      tags:
      - batches
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/BatchList'
          description: ''
    post:
      operationId: batches_create
      description: |-
        ViewSet for IngredientBatch management.

        Features:
        - Auto-generated batch_id (BATCH-1001, BATCH-1002, etc.)
        - Quantity tracking with FIFO ordering
        - Expiry date management and alerts
        - Cost tracking for financial reporting
        - Automatic ingredient total_quantity sync

        Endpoints:
        - GET    /api/batches/                  List all batches (paginated, filtered)
        - POST   /api/batches/                  Create new batch
        - GET    /api/batches/{id}/             Get batch details
        - PUT    /api/batches/{id}/             Full update
        - PATCH  /api/batches/{id}/             Partial update
        - DELETE /api/batches/{id}/             Delete batch

        Custom Actions:
        - GET    /api/batches/expiring/         Get batches expiring within 2 days
        - GET    /api/batches/{id}/consume/     Consume from batch (FIFO)
        - GET    /api/ingredients/{id}/batches/ Get all active batches for ingredient (FIFO)

        Filtering:
        - ?ingredient_id=1         Filter by ingredient
        - ?status=Active           Filter by status (Active, Expired, Used)
        - ?expiring_within=7       Batches expiring within N days
        - ?search=BATCH-1001       Search by batch_id or ingredient name
        - ?ordering=expire_date    Sort by field

        Permissions:
        - Storekeeper: Full CRUD (create, update, delete)
        - Manager: Full access (can do everything)
        - Baker: Read-only (list, detail)
        - Cashier & Others: No access
      tags:
      - batches
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BatchCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/BatchCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/BatchCreateRequest'
        required: true
      security:
      - tokenAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BatchCreate'
          description: ''
