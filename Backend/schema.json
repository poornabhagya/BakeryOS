components:
  schemas:
    BatchConsume:
      type: object
      description: |-
        Serializer for consuming from a batch.
        Used for POST /batches/{id}/consume/ endpoint.
      properties:
        amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Amount to consume from batch
      required:
      - amount
    BatchConsumeRequest:
      type: object
      description: |-
        Serializer for consuming from a batch.
        Used for POST /batches/{id}/consume/ endpoint.
      properties:
        amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Amount to consume from batch
      required:
      - amount
    BatchCreate:
      type: object
      description: |-
        Serializer for creating/updating batches.
        Includes custom validation rules.
      properties:
        ingredient_id:
          type: integer
          description: Ingredient this batch belongs to
        quantity:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Total quantity received for this batch
        current_qty:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Current remaining quantity in this batch
        cost_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          nullable: true
          description: Cost per unit (optional for financial tracking)
        made_date:
          type: string
          format: date-time
          description: Date batch was received/created
        expire_date:
          type: string
          format: date-time
          description: Expiry date for this batch
      required:
      - expire_date
      - ingredient_id
      - quantity
