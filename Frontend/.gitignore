# Frontend (.gitignore for React/Vite project)

# ============================================================
# Dependencies
# ============================================================
node_modules/
package-lock.json
yarn.lock

# ============================================================
# Build outputs
# ============================================================
dist/
build/
.next/
out/

# ============================================================
# Environment Variables (NEVER PUSH CREDENTIALS)
# ============================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================================
# IDE / Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.DS_Store

# ============================================================
# Testing
# ============================================================
.coverage
.nyc_output/
coverage/
.jest_cache/

# ============================================================
# Logs
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# Runtime data
# ============================================================
pids/
*.pid
*.seed
*.pid.lock

# ============================================================
# OS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ============================================================
# Temporary files
# ============================================================
*.tmp
*.temp
*.bak
.cache/

# ============================================================
# Browser Extensions
# ============================================================
.pem

# ============================================================
# Vite specific
# ============================================================
.vite/
